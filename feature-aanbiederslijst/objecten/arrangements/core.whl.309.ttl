@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:negatieve-whitelist-controle-stroom-afgebroken-geen-melding a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Indien een Whitelist-controle, in het kader van verantwoordelijkheid core.whl.307 en core.whl.308, niet kan worden uitgevoerd, of een negatief resultaat oplevert, breekt dit de voortgang af van de uitvoering van de functie en stellen de betrokken Applicatie-rollen elkaar hiervan niet op de hoogte." ;
    medmij:code "core.whl.309" ;
    medmij:elementName "Negatieve Whitelist-controle: stroom afgebroken, geen melding" ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Bij niet-slagen Whitelist-controle wordt voortgang gestopt; tegenpartij niet geïnformeerd." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> ;
    medmij:toelichting "Omdat het niet slagen van de Whitelist-controle duidt op een niet te vertrouwen tegenpartij, wordt deze daarvan niet op de hoogte gesteld." .

