@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-afsprakenstelsel--medmij-core a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:medmij-core ;
    medmij:componentClass medmij:Framework ;
    medmij:elementName "MedMij Afsprakenstelsel bevat MedMij Core" ;
    medmij:layer "—" ;
    medmij:mappingNote "Core is verplicht fundament van het totale Stelsel." ;
    medmij:whole obj:medmij-afsprakenstelsel ;
    medmij:wholeClass medmij:Framework .

