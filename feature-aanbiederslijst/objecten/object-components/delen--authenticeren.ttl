@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-delen--authenticeren a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:authenticeren ;
    medmij:componentClass medmij:Module ;
    medmij:elementName "Delen bevat Authenticeren" ;
    medmij:layer "—" ;
    medmij:mappingNote "DigiD-authenticatiestap als onderdeel van Delen." ;
    medmij:whole obj:delen ;
    medmij:wholeClass medmij:Service .

