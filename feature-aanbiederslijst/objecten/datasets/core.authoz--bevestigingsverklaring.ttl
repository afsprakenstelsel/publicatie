@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:bevestigingsverklaring a medmij:DataSet,
        medmij:Object ;
    medmij:code "(core.authoz.*)" ;
    medmij:elementName "Bevestigingsverklaring" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Gegevensset bij de functie Delen; DVA bevestigt ontvangst." .

