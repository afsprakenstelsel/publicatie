@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:oauth-client-list-ocl a medmij:DataProduct,
        medmij:Object ;
    medmij:code "(core.ocl.*)" ;
    medmij:elementName "OAuth Client List (OCL)" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Bevat DVP-clientnamen, toegestane diensten en notificatieadressen; opgehaald door DVA." .

