@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

obj:qual-arrangement a medmij:Object,
        medmij:QualificationRule ;
    medmij:code "—" ;
    medmij:elementName "Kwalificatieregel Arrangement" ;
    medmij:forClass medmij:Arrangement ;
    medmij:layer "—" ;
    medmij:mappingNote "Versie volgt afsprakenstelselversie; geen afzonderlijke kwalificatie." ;
    medmij:qualificationLevel "—" ;
    medmij:versioned true .

