@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:class-dataset a medmij:Object,
        medmij:ObjectClass ;
    medmij:classCode "DataSet" ;
    medmij:code "—" ;
    medmij:definition "Een set van gegevenselementen die als eenheid worden uitgewisseld, doorgaans op basis van een informatiestandaard." ;
    medmij:dutchName "Gegevensset" ;
    medmij:elementName "Gegevensset" ;
    medmij:examples "FHIR-profiel per gegevensdienst, gezondheidsgegevens conform MedMij-informatiemodel" ;
    medmij:layer "—" ;
    medmij:mappingNote "Set van gegevenselementen die als eenheid worden uitgewisseld op basis van een informatiestandaard." .

