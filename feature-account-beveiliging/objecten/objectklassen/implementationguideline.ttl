@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:class-implementationguideline a medmij:Object,
        medmij:ObjectClass ;
    medmij:classCode "ImplementationGuideline" ;
    medmij:code "—" ;
    medmij:definition "Een aanbeveling, toelichting of uitwerking die helpt bij correcte implementatie maar zelf geen eis is." ;
    medmij:dutchName "Implementatierichtlijn" ;
    medmij:elementName "Implementatierichtlijn" ;
    medmij:examples "Happy flow-beschrijvingen, uitzonderingstabellen, toelichtingen bij verantwoordelijkheden" ;
    medmij:layer "—" ;
    medmij:mappingNote "Aanbeveling of toelichting die helpt bij correcte implementatie, zelf geen eis." .

