@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:class-dataresource a medmij:Object,
        medmij:ObjectClass ;
    medmij:classCode "DataResource" ;
    medmij:code "—" ;
    medmij:definition "Een individuele, adresseerbare gegevensbron of API-endpoint waarvan de locatie in een dataproduct is opgenomen." ;
    medmij:dutchName "Gegevensbron / endpoint" ;
    medmij:elementName "Gegevensbron / endpoint" ;
    medmij:examples "Authorization endpoint, Token endpoint, Resource endpoint (per AanbiederGegevensdienst)" ;
    medmij:layer "—" ;
    medmij:mappingNote "Individuele, adresseerbare gegevensbron of API-endpoint opgenomen in een dataproduct." .

