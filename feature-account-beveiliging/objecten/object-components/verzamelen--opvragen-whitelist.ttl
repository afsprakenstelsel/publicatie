@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-verzamelen--opvragen-whitelist a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:opvragen-whitelist ;
    medmij:componentClass medmij:Module ;
    medmij:elementName "Verzamelen bevat Opvragen Whitelist" ;
    medmij:layer "—" ;
    medmij:mappingNote "Nodes halen WHL op als beveiligingscheck binnen Verzamelen." ;
    medmij:whole obj:verzamelen ;
    medmij:wholeClass medmij:Service .

