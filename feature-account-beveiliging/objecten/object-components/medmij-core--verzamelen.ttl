@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--verzamelen a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:verzamelen ;
    medmij:componentClass medmij:Service ;
    medmij:elementName "MedMij Core bevat Verzamelen" ;
    medmij:layer "—" ;
    medmij:mappingNote "Verzamelen is de primaire Core-gegevensdienst voor ophalen van gezondheidsdata." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

