      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Aanbiedersnamen in formaat <aanbieder>@medmij; naamgevingsbeleid van toepassing."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Aanbieders kunnen in hun directe of indirecte contact met Personen deze naam meegeven als hun 'MedMij-naam'. MedMij Beheer zorgt voor uniciteit en heeft het laatste woord bij het vaststellen ervan."
      }
    ]
  },
