  {
    "@id": "https://register.medmij.nl/objects/deelnemer-speelt-dvp-en-of-dva",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Een Deelnemer neemt de functionele rol van Dienstverlener persoon en/of Dienstverlener aanbieder op zich. Hierbij speelt één Deelnemer één of meerdere dienstverleners en wordt elke dienstverlener gespeeld door één Deelnemer."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.rollen.101"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Deelnemer speelt DVP en/of DVA"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Een Deelnemer neemt minimaal één serviceverlenersrol op zich; elke dienstverlener door één Deelnemer."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/automatisch-verzamelen-vereist-uitdrukkelijke-opdracht-persoon",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "De Dienstverlener persoon mag alleen gebruik maken van automatisch verzamelen bij een uitdrukkelijke opdracht van de Persoon."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.gegevensuitwisseling.101"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Automatisch verzamelen vereist uitdrukkelijke opdracht Persoon"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVP mag automatisch verzamelen alleen bij expliciete opdracht van Persoon."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/bron-en-context-opslaan-bij-verzamelde-informatie",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Dienstverlener persoon draagt ervoor zorg dat in het Dossier bij alle bij Dienstverlener aanbieder in het kader van een Gegevensdienst verzamelde informatie onlosmakelijk deze Dienstverlener aanbieder en Gegevensdienst als bron en verzamelcontext worden aangetekend. Dienstverlener persoon draagt ervoor zorg dat, in geval van het delen van informatie met een (andere) Aanbieder, deze bron- en context-informatie wordt meegeleverd aan de Dienstverlener aanbieder. Voor de benoeming van de bron wordt daarbij gebruik gemaakt van de Aanbiedersnaam. Voor de benoeming van de context wordt daarbij gebruik gemaakt van de betreffende Gegevensdienstnaam uit de Gegevensdienstnamenlijst."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.dossier.102"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Bron en context opslaan bij verzamelde informatie"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Bij verzamelde info in Dossier worden DVA en Gegevensdienst als bron/context vastgelegd."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Hiermee wordt geborgd dat bij de uitgewisselde zorg- en gezondheidsinformatie altijd duidelijk is bij welke bron (Dienstverlener aanbieder) en in welke context (Gegevensdienst) deze is verzameld. Een ontvanger van deze informatie kan deze meta-informatie gebruiken voor een betere interpretatie van de betreffende informatie."
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/class-service",
    "@type": [
      "https://register.medmij.nl/ontology/ObjectClass",
      "https://register.medmij.nl/ontology/Object"
