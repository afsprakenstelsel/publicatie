  {
    "@id": "https://register.medmij.nl/objects/informeren-persoon-bij-verwijderen-gegevens",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "\nIn het kader van de functie Verwijderen gegevens zal Persoon te allen tijde worden geïnformeerd:\n\n- Welke verzamelde gegevens precies verwijderd worden.\n- Dat verwijderen alleen in de PGO plaats vindt (en niet in enig bron systeem).\n- Dat verwijderde gegevens in een later stadium mogelijk niet meer opgevraagd kunnen worden uit de bron systemen (bijv. bij het verlopen van de beschikbaarheidstermijn).\n\nDe gepresenteerde informatie ondersteunt de gebruiksvriendelijkheid door gebruik te maken van taalniveau B1. Met de gepresenteerde informatie is het voor de Persoon duidelijk op welk deel van de inhoud van zijn dossier de functie verwijderen gegevens wordt toegepast, en wat hiervan de mogelijke consequenties zijn.\n"
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.dossier.106"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Informeren Persoon bij Verwijderen gegevens"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Persoon wordt geïnformeerd over wat verwijderd wordt en consequenties (taalniveau B1)."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/automatisch-opvragen-wordt-gelogd",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
