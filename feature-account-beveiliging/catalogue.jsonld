  {
    "@id": "https://register.medmij.nl/objects/dvp-biedt-persoon-functie-verzamelen",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Dienstverlener persoon biedt Persoon de functie Verzamelen om bij Dienstverlener aanbieder gezondheidsinformatie te verzamelen van Aanbieder, indien deze die informatie beschikbaar stelt, die op deze Persoon betrekking heeft en kan deze in een persoonlijk gezondheidsdossier (Dossier) van Persoon laten bewaren. Bij deze functie betrokken rollen gebruiken hiertoe het betreffende stroomdiagram."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.dossier.100"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVP biedt Persoon functie Verzamelen"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVP biedt functie om gezondheidsinfo bij DVA te verzamelen en in Dossier op te slaan."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Deze verantwoordelijkheid introduceert ook de notie van een persoonlijk gezondheidsdossier. Het opslaan in een persoonlijk gezondheidsdossier is optionele functionaliteit in het afsprakenstelsel. Wanneer deze functionaliteit wordt aangeboden moet ook het beheer worden aangeboden. Omdat de functie verzamelen zich over verschillende functionele rollen uitstrekt, is om interoperabiliteitsredenen de specificatie van het stroomdiagram aangehaald."
      }
    ]
  },
