  {
    "@id": "https://register.medmij.nl/objects/dvp-mag-automatisch-verzamelen-aanbieden",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Dienstverlener persoon mag de Persoon de functie Automatisch verzamelen aanbieden, mits uitgevoerd vanuit een gegeven langdurige toestemming, het doel is de gebruiksvriendelijkheid (performance) voor de Persoon te verbeteren of dat dit ten dienste staat van analytische oplossingen waarbij de afhankelijkheid van de Persoon de dienstverlening belemmert. De Dienstverlener persoon moet hier afspraken over opnemen in de Gebruikersovereenkomst die hij met de Persoon afsluit."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.dossier.107"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVP mag Automatisch verzamelen aanbieden"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Automatisch verzamelen mag alleen bij langdurige toestemming voor performance of analyse-doeleinden."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/stelselnode-aandeel-voor-99-9-beschikbaar",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Het aandeel van de MedMij Stelselnode in de functie Opvragen Whitelist is voor minstens 99,9% van de tijd beschikbaar. MedMij Registratie laat, na het niet beschikbaar raken van het aandeel van MedMij Stelselnode in de usecase, maximaal acht uren (480 minuten) verstrijken voordat het weer beschikbaar is."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.whl.301"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Stelselnode-aandeel voor ≥99,9% beschikbaar"
      }
    ],
    "https://register.medmij.nl/ontology/governedBy": [
      {
        "@id": "https://register.medmij.nl/objects/opvragen-whitelist"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Technologie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Na onbeschikbaarheid maximaal 480 minuten herstel; MedMij Registratie verantwoordelijk."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
