  {
    "@id": "https://register.medmij.nl/objects/persoon-kan-medmij-inhoud-traceren-in-dossier",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "\nIn het kader van de functie Raadplegen dossier zal Persoon te allen tijde moeten kunnen nagaan:\n\n- welke inhoud van het Dossier wel, en welke niet, via MedMij-verkeer van Dienstverlener aanbieder is betrokken van welke Aanbieder, en sindsdien niet is veranderd;\n- welke inhoud van het Dossier wel, en welke niet, via MedMij-verkeer bij Dienstverlener aanbieder is geplaatst ten behoeve van welke Aanbieder.\n"
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.dossier.104"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Persoon kan MedMij-inhoud traceren in Dossier"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Persoon kan altijd nagaan welke inhoud via MedMij-verkeer verzameld of geplaatst is."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Hiermee is het voor de Persoon duidelijk op welk deel van de inhoud van zijn dossier hij de aan het MedMij Afsprakenstelsel verbonden vertrouwen kan verbinden. Het is immers goed mogelijk dat een PGO alleen op bepaalde onderdelen deelneemt, en dus voldoet, aan het MedMij Afsprakenstelsel."
      }
    ]
  },
  {
