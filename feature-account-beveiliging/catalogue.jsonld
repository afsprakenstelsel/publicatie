  {
    "@id": "https://register.medmij.nl/objects/dva-biedt-authorization-server",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Dienstverlener aanbieder biedt een geautomatiseerde rol Authorization Server, voor het namens Aanbieders uitwisselen van gezondheidsinformatie met DVP Server. Deze rol wordt altijd gecombineerd met een Resource Server."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.rollen.201"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVA biedt Authorization Server"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Applicatie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVA biedt Authorization Server voor uitwisseling namens Aanbieders; altijd gecombineerd met Resource Server."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/medmij-beheer-beheert-en-publiceert-whitelist",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "MedMij Beheer beheert en publiceert een actuele Whitelist, namens de deelnemende Dienstverleners aanbieder en Dienstverleners persoon. De Whitelist beschrijft welke Nodes in MedMij-verkeer mogen deelnemen. De Whitelist voldoet aan wat over haar is bepaald in de Informatiemodellen."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.whl.100"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "MedMij Beheer beheert en publiceert Whitelist"
      }
    ],
    "https://register.medmij.nl/ontology/governedBy": [
      {
        "@id": "https://register.medmij.nl/objects/opvragen-whitelist"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Whitelist beschrijft welke Nodes mogen deelnemen aan MedMij-verkeer; voldoet aan Informatiemodellen."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/whitelist-controle-logisch-gescheiden-van-verwerking",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Voor zover de Dienstverlener aanbieder ervoor kiest de controle tegen de Whitelist na afloop van de TLS-handshake uit te voeren, is deze controle logisch gescheiden van de bedoelde eerstvolgende stap. De vereiste volgordelijkheid kan worden aangetoond door middel van code-inspecties, penetratietesten en inspecties van logs."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.whl.308"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Whitelist-controle logisch gescheiden van verwerking"
      }
    ],
    "https://register.medmij.nl/ontology/governedBy": [
      {
        "@id": "https://register.medmij.nl/objects/opvragen-whitelist"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Technologie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Controle na TLS-handshake is toegestaan maar moet logisch gescheiden zijn; aantoonbaar via code-inspectie."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "In geval van uitgaand verkeer kan de voorziene TLS-client de controle tegen de Whitelist al uitvoeren voordat hij de TLS-handshake initieert. In geval van inkomend verkeer echter, kan de TLS-server de zich aandienende TLS-client pas identificeren gedurende of na de TLS-handshake, aan de hand van het certificaat dat hij moet ontvangen. Door toe te staan dat niet alleen de Common Name maar ook een Subject Alternative Name de voor MedMij geautoriseerde hostname mag bevatten, biedt het MedMij Afsprakenstelsel aan deelnemers de mogelijkheid tot hergebruik van certificaten voor meerdere MedMij-nodes. Omdat er meerdere manieren zijn om dit na afloop van de TLS-handshake te implementeren, vereist het MedMij Afsprakenstelsel hiervoor geen vaste architectuurvariant (zoals met een reverse proxy), maar stelt het de vereiste van volgordelijkheid, naast een logische scheiding. Deze moeten kunnen worden aangetoond door middel van code-inspectie, penetratietesten en inspecties van logs."
      }
    ]
  },
