  {
    "@id": "https://register.medmij.nl/objects/medmij-beheer-publiceert-unieke-aanbiedersnamen",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "MedMij Beheer beheert en publiceert, in de Aanbiederslijst, unieke en gebruikersvriendelijke namen van Aanbieders, van het formaat <aanbieder>@medmij. Daarop is naamgevingsbeleid van toepassing."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.alst.101"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
