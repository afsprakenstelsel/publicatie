  {
    "@id": "https://register.medmij.nl/objects/whitelist-controle-v-r-tls-handshake-client-of-v-r-verwerking-server",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "\nDe Node die de TLS-client zou worden, voert de in verantwoordelijkheid core.whl.306 bedoelde controle tegen de Whitelist uit, voorafgaand aan de start van de TLS-handshake. Indien die controle niet kan worden uitgevoerd of een negatief resultaat oplevert, wordt de TLS-handshake niet gestart.\nDe Node die de TLS-server is, voert de in verantwoordelijkheid core.whl.306 bedoelde controle tegen de Whitelist geheel uit voordat enige volgende stap wordt gezet door de OAuth Authorization Server of OAuth Resource Server, volgens de specificaties van de functies Verzamelen en Delen. Deze vereiste wordt volgordelijkheid genoemd. Indien de controle tegen de Whitelist niet kan worden uitgevoerd, of een negatief resultaat oplevert, wordt de procesgang onmiddellijk afgebroken. De controle slaagt dan en slechts dan als op de Whitelist ten minste een van de volgende namen uit het door de TLS-client aangeboden certificaat voorkomen: de Common Name of een van de eventuele Subject Alternative Names.\n"
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.whl.307"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Whitelist-controle vóór TLS-handshake (client) of vóór verwerking (server)"
      }
    ],
    "https://register.medmij.nl/ontology/governedBy": [
      {
        "@id": "https://register.medmij.nl/objects/opvragen-whitelist"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Technologie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "TLS-client controleert vooraf; TLS-server controleert volledig vóór eerstvolgende stap (volgordelijkheid)."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
