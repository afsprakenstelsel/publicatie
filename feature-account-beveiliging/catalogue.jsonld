    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Het Aanbiedersregister bevat de gebruiksvriendelijke namen van aangesloten aanbieders, de bijbehorende identificerende gegevens, de bijbehorende gegevensdiensten en de uitwisselingsstatus. Het Aanbiedersregister bevat alleen de gegevens van aanbieders die voldoen aan de eisen en normen die in de DAP beschreven staan."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.reg.102"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
