  {
    "@id": "https://register.medmij.nl/objects/dvp-biedt-persoon-functie-delen",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Dienstverlener persoon biedt Persoon de functie Delen om bij Dienstverlener aanbieder ten behoeve van een Persoon, indien deze daartoe ontvankelijk is, gezondheidsinformatie te plaatsen die op deze Persoon betrekking heeft en die afkomstig is uit het Dossier. Bij deze functie betrokken rollen gebruiken hiertoe het betreffende stroomdiagram."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.dossier.101"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
