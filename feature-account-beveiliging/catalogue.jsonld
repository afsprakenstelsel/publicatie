      }
    ],
    "https://register.medmij.nl/ontology/definition": [
      {
        "@value": "Een concreet aangeboden functie voor gegevensuitwisseling tussen DVA en DVP, waarvoor een DVA zich kwalificeert."
      }
    ],
    "https://register.medmij.nl/ontology/dutchName": [
      {
        "@value": "Gegevensdienst"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Gegevensdienst"
      }
    ],
    "https://register.medmij.nl/ontology/examples": [
      {
        "@value": "Verzamelen, Delen, Abonneren, Beheren Toestemmingen"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "—"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Concreet aangeboden functie voor gegevensuitwisseling waarvoor een DVA zich kwalificeert."
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/dvp-server-auth-server-en-resource-server-implementeren-gegevensdienst",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Als een Dienstverleners persoon een zekere Gegevensdienst ontsluit ten behoeve van zijn Personen en daartoe laat leveren door een Dienstverlener aanbieder, zullen de DVP Server van die Dienstverlener persoon en de Authorization Server en Resource Server van die Dienstverlener aanbieder daarvoor de bij de Gegevensdienst horende functie implementeren en de bij de Gegevensdienst horende Systeemrollen gebruiken, zoals deze in de Catalogus zijn opgenomen, en zich daarbij conformeren aan de specificaties van die Systeemrollen zoals die zijn gepubliceerd op de plaats(en) waarnaar de Catalogus verwijst."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.gegevensdiensten.200"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVP Server, Auth.Server en Resource Server implementeren Gegevensdienst"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Applicatie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Juiste functie-implementaties en informatiestandaarden conform Catalogus; conformiteit borgt interoperabiliteit."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Zo wordt geborgd dat de juiste functie-implementaties en informatiestandaarden worden gebruikt. Ook wordt het correcte gebruik geborgd, wat bijdraagt aan interoperabiliteit en vertrouwen."
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/dva-ontsluit-minstens-n-gegevensdienst",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Elke Dienstverlener aanbieder ontsluit op elk moment minstens één Gegevensdienst."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.gegevensdiensten.101"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVA ontsluit minstens één Gegevensdienst"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Elke DVA ontsluit op elk moment minimaal één Gegevensdienst (Verzamelen of Delen)."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Het ontsluiten van een Gegevensdienst door een Dienstverlener aanbieder is, in deze versie van het MedMij Afsprakenstelsel, hetzij in het kader van Verzamelen of in het kader van Delen van zekere gezondheidsinformatie. De term 'ontsluiten' wordt hier gebruikt in plaats van de term 'aanbieden', omdat als aanbieder van een Gegevensdienst de Aanbieder wordt gezien, niet de Deelnemer (Dienstverlener aanbieder). De Deelnemer ontsluit de Gegevensdienst dus namens de Aanbieder die die Gegevensdienst aanbiedt."
      }
    ]
  },
  {
