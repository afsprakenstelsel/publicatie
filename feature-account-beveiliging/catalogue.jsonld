  {
    "@id": "https://register.medmij.nl/objects/definitie-medmij-verkeer",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "\nAls MedMij-verkeer is gedefinieerd: al het gegevensverkeer in het kader van enige functie-implementatie, onmiddellijk tussen twee verschillende van de vier volgende soorten rollen, namelijk:\n\n- ten eerste DVP Server,\n- ten tweede User Agent,\n- ten derde Authorization Server of Resource Server en\n- ten vierde MedMij Registratie,\n\nmet dien verstande dat:\n\n- in deze rollen telkens begrepen zijn de door hen eventueel verzorgde respectievelijke Autorisatie-rollen,\n- van deze rollen telkens uitgesloten zijn de door hen eventueel verzorgde Authenticatie-rollen, en\n- in deze rollen, met betrekking tot de functie-implementaties, telkens inbegrepen zijn de Nodes waarop zij functioneren.\n"
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.rollen.207"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Definitie MedMij-verkeer"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Applicatie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "MedMij-verkeer = verkeer tussen DVP Server, User Agent, Authorization/Resource Server en MedMij Registratie."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/dvp-notificeert-persoon-bij-48-uur-stagnerende-uitwisseling",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Indien uitwisseling van gegevens binnen een langdurige toestemming 48 uur of langer niet mogelijk is, is de DVP verplicht de Persoon te notificeren op een door de Persoon gewenste manier. Dit kan bijvoorbeeld in de app/browser, per e-mail of per SMS."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.gegevensuitwisseling.105"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVP notificeert Persoon bij 48 uur stagnerende uitwisseling"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Verplichte notificatie als langdurige toestemming 48 uur niet kan worden gebruikt."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/medmij-beheer-biedt-functie-opvragen-aanbiederslijst",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "MedMij Beheer biedt aan Dienstverleners persoon een functie (Opvragen Aanbiederslijst) om de actuele versie van die Aanbiederslijst op te vragen. Betrokken rollen gebruiken hiertoe het betreffende stroomdiagram."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
