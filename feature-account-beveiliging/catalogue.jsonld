  {
    "@id": "https://register.medmij.nl/objects/dva-verifieert-toestemming-persoon-v-r-verzamelen",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "\nDienstverlener aanbieder vergewist zich ervan, elke keer opnieuw voordat hij Persoon gezondheidsinformatie van Aanbieder laat verzamelen door middel van de functie Verzamelen, dat deze Persoon uitdrukkelijk Toestemming heeft gegeven aan Aanbieder om de in de Gegevensdienst betrokken gezondheidsinformatie aan Dienstverlener persoon ter beschikking te laten stellen. De vraag om Toestemming heeft een vaste formulering, die is opgenomen in de functie Autoriseren. Deze Toestemming is:\n\n- geldig voor de huidige sessie, of\n- bij langdurige toestemming geldig voor onbepaalde tijd, mits minimaal één keer per 6 maanden gebruikgemaakt wordt van de toestemming en deze niet ingetrokken is.\n"
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.autorisatie.100"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVA verifieert Toestemming Persoon vóór Verzamelen"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Elke keer opnieuw: uitdrukkelijke Toestemming Persoon vereist; geldig voor sessie of 6 maanden (langdurig)."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/dvp-notificeert-persoon-bij-inactief-account",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "De Dienstverlener persoon moet de Persoon notificeren per e-mail, SMS of pushbericht (via de DVP-app, indien beschikbaar) van het feit dat het account de status 'inactief' heeft gekregen. De notificatie vermeldt expliciet dat lopende langdurige toestemmingen zijn gepauzeerd en bevat een directe link naar de heractivatieprocedure, totdat de Persoon opnieuw inlogt."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.account.103"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVP notificeert Persoon bij inactief account"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVP stuurt e-mail, SMS of push bij statuswijziging naar inactief; melding bevat heractivatielink."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/logging-van-autorisatieflows-bewaartermijn",
