    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Dienstverlener persoon biedt aan Persoon, in het kader van de toepasselijke Dienstverleningsovereenkomst, een geautomatiseerde rol ter gebruik, hier genoemd: DVP Server. Eén Dienstverlener persoon biedt één of meerdere DVP Servers en elke DVP Server wordt door één Dienstverlener persoon geboden."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.rollen.200"
      }
    ],
