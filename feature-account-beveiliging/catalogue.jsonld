        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVP's kunnen actuele Aanbiederslijst opvragen via stroomdiagram."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/account-wordt-actief-bij-hergebruik-persoon",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "De Dienstverlener persoon geeft een inactief account de status 'actief' zodra de Persoon opnieuw inlogt via meerfactorauthenticatie (MFA). De Persoon ontvangt hierbij een melding dat het account reactiveert en dient de geldende privacyverklaring opnieuw te bevestigen indien deze gewijzigd is."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.account.102"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Account wordt actief bij hergebruik Persoon via MFA"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVP herstelt status 'actief' na MFA-inlog; melding en evt. herbevestiging privacyverklaring vereist."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
