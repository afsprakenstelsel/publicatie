        "@value": false
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/oauth-2-0-authorization-code-als-grant-type",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "\nEen aanpassing - Ten behoeve van het autoriseren van DVP Server voor toegang tot Resource Server, in het kader van de functies Verzamelen en Delen, zullen de betrokken User Agent, DVP Server, Authorization Server en Resource Server gebruik maken van OAuth 2.0, waarbij als grant type gebruik wordt gemaakt van Authorization Code en waarbij:\n\n- de rol van OAuth Resource Owner wordt verzorgd door de Persoon;\n- de rol van OAuth Client wordt verzorgd door de DVP Server;\n- de rol van OAuth Resource Server wordt verzorgd door de Resource Server;\n- de rol van OAuth Authorization Server wordt verzorgd door de Authorization Server.\n"
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.rollen.206"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "OAuth 2.0 Authorization Code als grant type"
      }
    ],
