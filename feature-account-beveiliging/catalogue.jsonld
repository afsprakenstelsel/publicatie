        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVP biedt functie om gezondheidsinfo vanuit Dossier te plaatsen bij DVA."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
  {
    "@id": "https://register.medmij.nl/objects/automatisch-verzamelen-alleen-voor-performance-of-analyse",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "De Dienstverlener persoon mag alleen de functie Automatisch verzamelen aanbieden indien het doel is de performance voor de Persoon te verbeteren. Daarnaast kan gebruikgemaakt worden van automatisch verzamelen ten dienste van analytische oplossingen, zoals AI modules en andere technische toepassingen, waarbij de afhankelijkheid van de gebruiker een bottleneck is voor de te leveren dienst."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.gegevensuitwisseling.100"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Automatisch verzamelen alleen voor performance of analyse"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVP mag alleen automatisch verzamelen als doel performance voor Persoon is of analytische oplossing."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
