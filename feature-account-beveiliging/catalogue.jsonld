  {
    "@id": "https://register.medmij.nl/objects/medmij-beheer-neemt-dva-op-in-aanbiederslijst-na-toetsing",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "MedMij Beheer zal alleen in de Aanbiederslijst opnemen dat een zekere Gegevensdienst door een zekere Aanbieder via een Dienstverlener aanbieder wordt aangeboden, indien zij (Stichting MedMij) heeft vastgesteld dat de Dienstverlener aanbieder voldoet aan de specifiek op die Gegevensdienst toepasselijke eisen en de normen die staan beschreven in de DAP en aanverwante documenten."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.gegevensdiensten.102"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "MedMij Beheer neemt DVA op in Aanbiederslijst na toetsing"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Opname alleen als DVA voldoet aan DAP-eisen voor de betreffende Gegevensdienst."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "De Dienstverlener aanbieder heeft minimaal één Aanbieder nodig om zich te kwalificeren in het MedMij Afsprakenstelsel voor een informatiestandaard."
      }
    ]
  },
