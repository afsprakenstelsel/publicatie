  {
    "@id": "https://register.medmij.nl/objects/medmij-beheer-beheert-en-publiceert-oauth-client-list",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "MedMij Beheer beheert en publiceert een actuele OAuth Client List, namens de deelnemende Dienstverleners persoon. De gepubliceerde OAuth Client List bevat steeds en slechts alle actuele entries, en beschrijft van elke OAuth Client: wat de gebruikersvriendelijke namen zijn die voor de Dienstverleners persoon worden gebruikt in de Toestemmingsverklaring en de Bevestigingsverklaring."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.ocl.100"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "MedMij Beheer beheert en publiceert OAuth Client List"
      }
    ],
    "https://register.medmij.nl/ontology/governedBy": [
      {
        "@id": "https://register.medmij.nl/objects/opvragen-oauth-client-list"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "OCL bevat gebruiksvriendelijke namen en erkende diensten per DVP-client (OAuth Client)."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "De OAuth Client List bevat dus geen namen voor Dienstverleners aanbieder. Dat is niet nodig, omdat deze niet voorkomen in de Toestemmingsverklaring."
      }
    ]
  },
