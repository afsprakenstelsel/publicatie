  {
    "@id": "https://register.medmij.nl/objects/persoon-moet-actief-account-hebben-bij-dvp",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Voor het inrichten van een MedMij dossier en voor het gebruikmaken van de verschillende MedMij functies moet de Persoon een actief account hebben bij de Dienstverlener persoon. De Dienstverlener persoon biedt bij het aanmaken en bij het inloggen op het account meerfactorauthenticatie (MFA) aan als verplichte beveiligingsmaatregel."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.account.100"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Persoon moet een actief account hebben bij DVP"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Business"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Vereist voor inrichten Dossier en gebruik MedMij-functies; MFA verplicht bij aanmaken en inloggen."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Meerfactorauthenticatie (MFA) vormt een essentiële beveiligingslaag voor toegang tot gezondheidsgegevens. De Dienstverlener persoon kan kiezen uit erkende MFA-methoden zoals een authenticator-app, SMS-code of hardwaretoken, mits deze voldoen aan de beveiligingseisen uit het MedMij Afsprakenstelsel."
      }
    ]
  },
