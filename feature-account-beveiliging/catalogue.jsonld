  {
    "@id": "https://register.medmij.nl/objects/dva-biedt-resource-server",
    "@type": [
      "https://register.medmij.nl/ontology/Object",
      "https://register.medmij.nl/ontology/Arrangement"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Dienstverlener aanbieder biedt een geautomatiseerde rol Resource Server, voor het namens Aanbieders uitwisselen van gezondheidsinformatie met DVP Server. Eén Dienstverlener aanbieder biedt één of meer combinaties van één Authorization Server en één Resource Server en elke combinatie van één Authorization Server en één Resource Server wordt door één Dienstverlener aanbieder geboden."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.rollen.202"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "DVA biedt Resource Server"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Applicatie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "DVA biedt Resource Server; 1 DVA — 1..n combinaties van Authorization Server + Resource Server."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ]
  },
