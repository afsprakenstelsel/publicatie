  {
    "@id": "https://register.medmij.nl/objects/negatieve-whitelist-controle-stroom-afgebroken-geen-melding",
    "@type": [
      "https://register.medmij.nl/ontology/Arrangement",
      "https://register.medmij.nl/ontology/Object"
    ],
    "https://register.medmij.nl/ontology/arrangementText": [
      {
        "@value": "Indien een Whitelist-controle, in het kader van verantwoordelijkheid core.whl.307 en core.whl.308, niet kan worden uitgevoerd, of een negatief resultaat oplevert, breekt dit de voortgang af van de uitvoering van de functie en stellen de betrokken Applicatie-rollen elkaar hiervan niet op de hoogte."
      }
    ],
    "https://register.medmij.nl/ontology/code": [
      {
        "@value": "core.whl.309"
      }
    ],
    "https://register.medmij.nl/ontology/elementName": [
      {
        "@value": "Negatieve Whitelist-controle: stroom afgebroken, geen melding"
      }
    ],
    "https://register.medmij.nl/ontology/governedBy": [
      {
        "@id": "https://register.medmij.nl/objects/opvragen-whitelist"
      }
    ],
    "https://register.medmij.nl/ontology/layer": [
      {
        "@value": "Technologie"
      }
    ],
    "https://register.medmij.nl/ontology/mappingNote": [
      {
        "@value": "Bij niet-slagen Whitelist-controle wordt voortgang gestopt; tegenpartij niet geïnformeerd."
      }
    ],
    "https://register.medmij.nl/ontology/sourceUrl": [
      {
        "@id": "https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core"
      }
    ],
    "https://register.medmij.nl/ontology/toelichting": [
      {
        "@value": "Omdat het niet slagen van de Whitelist-controle duidt op een niet te vertrouwen tegenpartij, wordt deze daarvan niet op de hoogte gesteld."
      }
    ]
  },
