@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--aanbiedersregister-reg a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:aanbiedersregister-reg ;
    medmij:componentClass medmij:Dataproduct ;
    medmij:elementName "MedMij Core bevat Aanbiedersregister (REG)" ;
    medmij:layer "—" ;
    medmij:mappingNote "REG is het publieke, human-readable register van Aanbieders en hun diensten." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

