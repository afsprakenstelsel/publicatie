@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--resource-server a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:resource-server ;
    medmij:componentClass medmij:Component ;
    medmij:elementName "MedMij Core bevat Resource Server" ;
    medmij:layer "—" ;
    medmij:mappingNote "Resource Server is de DVA-component voor gegevensontsluiting." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

