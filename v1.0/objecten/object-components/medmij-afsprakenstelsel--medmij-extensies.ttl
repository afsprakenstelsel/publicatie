@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-afsprakenstelsel--medmij-extensies a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:medmij-extensies ;
    medmij:componentClass medmij:Framework ;
    medmij:elementName "MedMij Afsprakenstelsel bevat MedMij Extensies" ;
    medmij:layer "—" ;
    medmij:mappingNote "Extensies zijn optionele uitbreiding bovenop Core." ;
    medmij:whole obj:medmij-afsprakenstelsel ;
    medmij:wholeClass medmij:Framework .

