@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-verzamelen--toestemmingsverklaring a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:toestemmingsverklaring ;
    medmij:componentClass medmij:Dataset ;
    medmij:elementName "Verzamelen bevat Toestemmingsverklaring" ;
    medmij:layer "—" ;
    medmij:mappingNote "Toestemmingsverklaring (wie, wanneer, welke dienst) is de DataSet bij autorisatie." ;
    medmij:whole obj:verzamelen ;
    medmij:wholeClass medmij:Service .

