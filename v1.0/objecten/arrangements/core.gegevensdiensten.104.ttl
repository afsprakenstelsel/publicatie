@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:dva-levert-nog-1-uur-na-verlopen-aanbiederslijst-vermelding a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Het in verantwoordelijkheid core.gegevensdiensten.103 bepaalde is ook van toepassing zolang de geldigheid van de toepasselijke vermelding in de Aanbiederslijst niet langer dan één uur (3600 seconden) geleden is verstreken." ;
    medmij:code "core.gegevensdiensten.104" ;
    medmij:elementName "DVA levert nog 1 uur na verlopen Aanbiederslijst-vermelding" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Ruimte voor na-ijlende sessies die de vorige versie van de Aanbiederslijst gebruiken." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> ;
    medmij:toelichting "Zo wordt ervoor ruimte geboden dat na-ijlende sessies, die nog gebruik maken van de verstrijkende versie van de Aanbiederslijst, nog kunnen worden afgemaakt." .

