@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:class-component a medmij:Object,
        medmij:ObjectClass ;
    medmij:classCode "Component" ;
    medmij:code "—" ;
    medmij:definition "Een technische rol in de architectuur; een setje verantwoordelijkheden dat door een of meer systemen wordt ingevuld." ;
    medmij:dutchName "Architectuurcomponent" ;
    medmij:elementName "Architectuurcomponent" ;
    medmij:examples "DVP Server, Authorization Server, Resource Server, User Agent, MedMij Registratie" ;
    medmij:layer "—" ;
    medmij:mappingNote "Technische rol in de architectuur; verantwoordelijkheden ingevuld door een of meer systemen." .

