@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:class-dataproduct a medmij:Object,
        medmij:ObjectClass ;
    medmij:classCode "DataProduct" ;
    medmij:code "—" ;
    medmij:definition "Een gepubliceerd, samengesteld gegevensproduct dat door MedMij Beheer wordt beheerd en verspreid." ;
    medmij:dutchName "Dataproduct" ;
    medmij:elementName "Dataproduct" ;
    medmij:examples "Aanbiederslijst (ZAL), OAuth Client List (OCL), Gegevensdienstnamenlijst (GNL), Whitelist (WHL), Aanbiedersregister" ;
    medmij:layer "—" ;
    medmij:mappingNote "Gepubliceerd, samengesteld gegevensproduct beheerd en verspreid door MedMij Beheer." .

