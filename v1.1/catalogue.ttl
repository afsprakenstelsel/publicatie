    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:medmij-beheer-beheert-en-publiceert-aanbiederslijst a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "MedMij Beheer beheert en publiceert een Aanbiederslijst, namens de deelnemende Dienstverlener aanbieder. De gepubliceerde Aanbiederslijst bevat steeds en slechts alle actuele entries, en beschrijft van elke Aanbieder: welke Gegevensdiensten deze momenteel aanbiedt, en welke technische adressen daarvoor moeten worden aangesproken bij de Dienstverlener aanbieder, gegeven een zekere Interfaceversie." ;
    medmij:code "core.alst.100" ;
    medmij:elementName "MedMij Beheer beheert en publiceert Aanbiederslijst" ;
    medmij:governedBy obj:opvragen-aanbiederslijst ;
    medmij:layer "Business" ;
    medmij:mappingNote "Aanbiederslijst bevat alle actuele Aanbieders met Gegevensdiensten en endpoints per Interfaceversie." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> ;
    medmij:toelichting "Deze afspraak wijst MedMij Beheer de verantwoordelijkheid toe om ten behoeve van alle Dienstverleners persoon een lijst te verspreiden van Aanbieders en de door hen aangeboden Gegevensdiensten. Zonder deze functie zou het stelsel niet functioneren." .

obj:medmij-beheer-beheert-en-publiceert-gnl a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "MedMij Beheer beheert en publiceert de Gegevensdienstnamenlijst. Deze beschrijft welke gebruikersvriendelijke namen horen bij welke Gegevensdiensten. De Gegevensdienstnamenlijst voldoet aan wat over haar is bepaald in de Informatiemodellen." ;
    medmij:code "core.gnl.100" ;
    medmij:elementName "MedMij Beheer beheert en publiceert GNL" ;
    medmij:governedBy obj:opvragen-gegevensdienstnamenlijst ;
    medmij:layer "Business" ;
    medmij:mappingNote "GNL beschrijft gebruiksvriendelijke namen per Gegevensdienst; voldoet aan Informatiemodellen." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:medmij-beheer-beheert-en-publiceert-oauth-client-list a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "MedMij Beheer beheert en publiceert een actuele OAuth Client List, namens de deelnemende Dienstverleners persoon. De gepubliceerde OAuth Client List bevat steeds en slechts alle actuele entries, en beschrijft van elke OAuth Client: wat de gebruikersvriendelijke namen zijn die voor de Dienstverleners persoon worden gebruikt in de Toestemmingsverklaring en de Bevestigingsverklaring." ;
    medmij:code "core.ocl.100" ;
    medmij:elementName "MedMij Beheer beheert en publiceert OAuth Client List" ;
    medmij:governedBy obj:opvragen-oauth-client-list ;
    medmij:layer "Business" ;
    medmij:mappingNote "OCL bevat gebruiksvriendelijke namen en erkende diensten per DVP-client (OAuth Client)." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> ;
    medmij:toelichting "De OAuth Client List bevat dus geen namen voor Dienstverleners aanbieder. Dat is niet nodig, omdat deze niet voorkomen in de Toestemmingsverklaring." .

obj:medmij-beheer-beheert-en-publiceert-whitelist a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "MedMij Beheer beheert en publiceert een actuele Whitelist, namens de deelnemende Dienstverleners aanbieder en Dienstverleners persoon. De Whitelist beschrijft welke Nodes in MedMij-verkeer mogen deelnemen. De Whitelist voldoet aan wat over haar is bepaald in de Informatiemodellen." ;
    medmij:code "core.whl.100" ;
    medmij:elementName "MedMij Beheer beheert en publiceert Whitelist" ;
