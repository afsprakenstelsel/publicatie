obj:aanbieder-verantwoordelijk-voor-kwaliteit-registergegevens a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Aanbieders zijn zelf verantwoordelijk voor de kwaliteit van de informatie die in het register staat. Gewenste wijzigingen kunnen worden doorgegeven aan MedMij Beheer of worden doorgevoerd via de geboden interfaces." ;
    medmij:code "core.req.103" ;
    medmij:elementName "Aanbieder verantwoordelijk voor kwaliteit registergegevens" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Wijzigingen doorgeven aan MedMij Beheer of via geboden interfaces." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:aanbiedersregister-99-9-beschikbaar-max-480-min-onbeschikbaar a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Het Aanbiedersregister is voor minstens 99,9% van de tijd beschikbaar. Onbeschikbaarheid duurt maximaal acht uren (480 minuten)." ;
    medmij:code "core.reg.300" ;
    medmij:elementName "Aanbiedersregister ≥99,9% beschikbaar; max. 480 min. onbeschikbaar" ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Hoge beschikbaarheidseis voor publiek raadpleegbaar register." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:aanbiedersregister-is-human-readable a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Het Aanbiedersregister is voor mensen begrijpelijk (human readable) weergegeven." ;
    medmij:code "core.reg.101" ;
    medmij:elementName "Aanbiedersregister is human-readable" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Register begrijpelijk weergegeven voor mensen." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:abonneren-extensie a medmij:Object,
        medmij:Service ;
    medmij:code "—" ;
    medmij:elementName "Abonneren (extensie)" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Uitbreiding op Core; DVP abonneert zich op pushberichten van DVA." .

obj:account-wordt-actief-bij-hergebruik-persoon a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "De dienstverlener persoon geeft een inactief account de status 'actief' zodra de Persoon weer gebruikmaakt van het account." ;
    medmij:code "core.account.102" ;
    medmij:elementName "Account wordt actief bij hergebruik Persoon" ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVP herstelt status 'actief' zodra Persoon account weer gebruikt." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:account-wordt-inactief-na-6-maanden-niet-gebruik a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "De Dienstverlener persoon geeft een account de status 'inactief' zodra een account 6 maanden lang niet gebruikt is door de Persoon." ;
    medmij:code "core.account.101" ;
    medmij:elementName "Account wordt inactief na 6 maanden niet-gebruik" ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVP geeft account status 'inactief' na 6 maanden zonder gebruik." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:auth-server-haalt-ocl-minstens-elke-15-min-op a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Authorization Server betrekt minstens elke vijftien minuten (900 seconden) de meest recente OAuth Client List van MedMij Registratie." ;
    medmij:code "core.ocl.201" ;
    medmij:elementName "Auth.Server haalt OCL minstens elke 15 min op" ;
    medmij:governedBy obj:opvragen-oauth-client-list ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Maximaal 900 seconden oud; meest recente OCL van MedMij Registratie." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:auth-server-valideert-ocl-tegen-xml-schema a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Authorization Server valideert elke nieuwe verkregen OAuth Client List tegen het XML-schema van de OAuth Client List." ;
    medmij:code "core.ocl.202" ;
    medmij:elementName "Auth.Server valideert OCL tegen XML-schema" ;
    medmij:governedBy obj:opvragen-oauth-client-list ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Elke nieuw verkregen OCL gevalideerd tegen gepubliceerd XML-schema." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:authentication-server a medmij:Component,
        medmij:Object ;
    medmij:code "core.rollen.205" ;
    medmij:elementName "Authentication Server" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Externe component (DigiD) die identiteit van Persoon vaststelt." .

obj:authorization-server-gebruikt-authentication-server a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Ten behoeve van het authenticeren van Persoon, zal de betrokken Authorization Server, in de rol van Authentication Client, gebruikmaken van de Authentication Server van een Dienstverlener authenticatie." ;
    medmij:code "core.rollen.205" ;
    medmij:elementName "Authorization Server gebruikt Authentication Server" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Authorization Server gebruikt externe Authentication Server (DigiD) als Authentication Client." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:automatisch-opvragen-wordt-gelogd a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Bij geautomatiseerd verzamelen moet bij het request gelogd worden dat het om een automatische opvraging gaat." ;
    medmij:code "core.gegevensuitwisseling.200" ;
    medmij:elementName "Automatisch opvragen wordt gelogd" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Bij elke automatische opvraging wordt gelogd dat het een automatisch request betreft." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:automatisch-verzamelen-alleen-voor-actieve-accounts a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "De Dienstverlener persoon mag alleen geautomatiseerd gegevens verzamelen voor actieve accounts." ;
    medmij:code "core.gegevensuitwisseling.103" ;
    medmij:elementName "Automatisch verzamelen alleen voor actieve accounts" ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVP mag geen geautomatiseerde uitwisseling doen voor inactieve accounts." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:automatisch-verzamelen-alleen-voor-performance-of-analyse a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "De Dienstverlener persoon mag alleen de functie Automatisch verzamelen aanbieden indien het doel is de performance voor de Persoon te verbeteren. Daarnaast kan gebruikgemaakt worden van automatisch verzamelen ten dienste van analytische oplossingen, zoals AI modules en andere technische toepassingen, waarbij de afhankelijkheid van de gebruiker een bottleneck is voor de te leveren dienst." ;
    medmij:code "core.gegevensuitwisseling.100" ;
    medmij:elementName "Automatisch verzamelen alleen voor performance of analyse" ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVP mag alleen automatisch verzamelen als doel performance voor Persoon is of analytische oplossing." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:automatisch-verzamelen-vereist-uitdrukkelijke-opdracht-persoon a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "De Dienstverlener persoon mag alleen gebruik maken van automatisch verzamelen bij een uitdrukkelijke opdracht van de Persoon." ;
    medmij:code "core.gegevensuitwisseling.101" ;
    medmij:elementName "Automatisch verzamelen vereist uitdrukkelijke opdracht Persoon" ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVP mag automatisch verzamelen alleen bij expliciete opdracht van Persoon." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:backchannel-node a medmij:Component,
        medmij:Object ;
    medmij:code "core.rollen.300" ;
    medmij:elementName "Backchannel Node" ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Node die communiceert met andere backchannel-nodes; gebaseerd op lijstregistraties." .

obj:backchannel-nodes-controleren-whitelist-voor-verkeer a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Backchannel Nodes laten, elk hunnerzijds, backchannel-verkeer over het MedMij-netwerk dan en alleen dan doorgang vinden, nadat zij hebben vastgesteld dat de hostname van de andere Node, waarmee verbinding gemaakt zou worden, op de meest actuele Whitelist voorkomt." ;
    medmij:code "core.whl.306" ;
    medmij:elementName "Backchannel Nodes controleren Whitelist voor verkeer" ;
    medmij:governedBy obj:opvragen-whitelist ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Backchannel-verkeer alleen toegestaan als hostname andere Node op Whitelist staat." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> ;
    medmij:toelichting "In geval van frontchannel-verkeer vindt er geen Server Authorization plaats." .

obj:batch-automatisch-verzamelen-23-00-06-00-gespreid a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Batch-gewijs geautomatiseerd verzamelen voor meerdere Personen mag alleen in het tijdslot van 23.00 uur tot 6.00 uur en niet allemaal op hetzelfde tijdstip." ;
    medmij:code "core.gegevensuitwisseling.201" ;
    medmij:elementName "Batch automatisch verzamelen: 23:00–06:00, gespreid" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Batch-gewijs verzamelen voor meerdere Personen alleen in nachtvenster, niet simultaan." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

obj:beeindigingsverklaring a medmij:DataSet,
        medmij:Object ;
    medmij:code "(core.toestemming.*)" ;
    medmij:elementName "Beeindigingsverklaring" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Gegevensset waarmee Persoon een abonnement of langdurige toestemming intrekt." .

obj:bron-en-context-opslaan-bij-verzamelde-informatie a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Dienstverlener persoon draagt ervoor zorg dat in het Dossier bij alle bij Dienstverlener aanbieder in het kader van een Gegevensdienst verzamelde informatie onlosmakelijk deze Dienstverlener aanbieder en Gegevensdienst als bron en verzamelcontext worden aangetekend, inclusief het tijdstip van verzameling (ISO 8601-formaat). Dienstverlener persoon draagt ervoor zorg dat, in geval van het delen van informatie met een (andere) Aanbieder, deze bron-, context- en tijdstempel-informatie wordt meegeleverd aan de Dienstverlener aanbieder. Voor de benoeming van de bron wordt daarbij gebruik gemaakt van de Aanbiedersnaam. Voor de benoeming van de context wordt daarbij gebruik gemaakt van de betreffende Gegevensdienstnaam uit de Gegevensdienstnamenlijst." ;
    medmij:code "core.dossier.102" ;
    medmij:elementName "Bron, context en tijdstip opslaan bij verzamelde informatie" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Bij verzamelde info in Dossier worden DVA, Gegevensdienst en tijdstip (ISO 8601) als bron/context/tijdstempel vastgelegd." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> ;
    medmij:toelichting "Hiermee wordt geborgd dat bij de uitgewisselde zorg- en gezondheidsinformatie altijd duidelijk is bij welke bron (Dienstverlener aanbieder), in welke context (Gegevensdienst) en op welk tijdstip deze is verzameld. De toevoeging van het verzameltijdstip maakt het mogelijk om de actualiteit van gegevens te beoordelen en ondersteunt het bijhouden van een audittrail." .

