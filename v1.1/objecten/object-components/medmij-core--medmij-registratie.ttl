@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--medmij-registratie a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:medmij-registratie ;
    medmij:componentClass medmij:Component ;
    medmij:elementName "MedMij Core bevat MedMij Registratie" ;
    medmij:layer "—" ;
    medmij:mappingNote "Centrale component voor lijstbeheer en publicatie (Stelselnode)." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

