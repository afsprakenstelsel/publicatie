@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:class-module a medmij:Object,
        medmij:ObjectClass ;
    medmij:classCode "Module" ;
    medmij:code "—" ;
    medmij:definition "Een herbruikbare functionele bouwsteen die een samenhangend cluster van functies omvat." ;
    medmij:dutchName "Functionele module" ;
    medmij:elementName "Functionele module" ;
    medmij:examples "Autoriseren, Authenticeren, Opvragen Aanbiederslijst" ;
    medmij:layer "—" ;
    medmij:mappingNote "Herbruikbare functionele bouwsteen met samenhangend cluster van functies." .

