@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

obj:qual-requirement a medmij:Object,
        medmij:QualificationRule ;
    medmij:code "—" ;
    medmij:elementName "Kwalificatieregel Requirement" ;
    medmij:forClass medmij:Requirement ;
    medmij:layer "—" ;
    medmij:mappingNote "Systeem- of deelnemer-kwalificatie afhankelijk van aard van eis." ;
    medmij:qualificationLevel "system / participant" ;
    medmij:versioned true .

