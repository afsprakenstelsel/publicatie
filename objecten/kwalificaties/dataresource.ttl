    medmij:elementName "Kwalificatieregel DataResource" ;
    medmij:forClass medmij:DataResource ;
    medmij:layer "—" ;
    medmij:mappingNote "Dynamisch; opgenomen als NodeCapability of NodeMetadata." ;
    medmij:qualificationLevel "—" ;
    medmij:versioned false .

