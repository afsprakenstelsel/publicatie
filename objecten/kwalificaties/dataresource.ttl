@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:qual-dataresource
    a medmij:Object, medmij:QualificationRule ;
    medmij:elementName "Kwalificatieregel DataResource" ;
    medmij:code "—" ;
    medmij:objectClass medmij:QualificationRule ;
    medmij:layer "—" ;
    medmij:mappingNote "Dynamisch; opgenomen als NodeCapability of NodeMetadata." ;
    medmij:forClass medmij:DataResource ;
    medmij:qualificationLevel "—" ;
    medmij:versioned "false"^^xsd:boolean .
