@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

obj:qual-module a medmij:Object,
        medmij:QualificationRule ;
    medmij:code "—" ;
    medmij:elementName "Kwalificatieregel Module" ;
    medmij:forClass medmij:Module ;
    medmij:layer "—" ;
    medmij:mappingNote "Onderdeel van Service of Framework; geen zelfstandige kwalificatie." ;
    medmij:qualificationLevel "—" ;
    medmij:versioned true .

