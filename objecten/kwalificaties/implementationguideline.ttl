@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

obj:qual-implementationguideline a medmij:Object,
        medmij:QualificationRule ;
    medmij:code "—" ;
    medmij:elementName "Kwalificatieregel ImplementationGuideline" ;
    medmij:forClass medmij:ImplementationGuideline ;
    medmij:layer "—" ;
    medmij:mappingNote "Informatief; geen kwalificatie." ;
    medmij:qualificationLevel "—" ;
    medmij:versioned true .

