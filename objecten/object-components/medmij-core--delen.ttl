@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--delen a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:delen ;
    medmij:componentClass medmij:Service ;
    medmij:elementName "MedMij Core bevat Delen" ;
    medmij:layer "—" ;
    medmij:mappingNote "Delen is de Core-gegevensdienst voor plaatsen van gezondheidsdata bij DVA." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

