@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:comp-verzamelen--authenticeren
    a medmij:Object, medmij:ObjectComponent ;
    medmij:elementName "Verzamelen bevat Authenticeren" ;
    medmij:code "—" ;
    medmij:objectClass medmij:ObjectComponent ;
    medmij:layer "—" ;
    medmij:mappingNote "DigiD-authenticatiestap als onderdeel van Verzamelen." ;
    medmij:whole obj:verzamelen ;
    medmij:wholeClass medmij:Service ;
    medmij:component obj:authenticeren ;
    medmij:componentClass medmij:Module .
