@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--whitelist-whl a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:whitelist-whl ;
    medmij:componentClass medmij:Dataproduct ;
    medmij:elementName "MedMij Core bevat Whitelist (WHL)" ;
    medmij:layer "—" ;
    medmij:mappingNote "WHL is het DataProduct voor Node-autorisatie in het MedMij-netwerk." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

