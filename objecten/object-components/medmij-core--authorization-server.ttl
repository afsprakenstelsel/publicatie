@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--authorization-server a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:authorization-server ;
    medmij:componentClass medmij:Component ;
    medmij:elementName "MedMij Core bevat Authorization Server" ;
    medmij:layer "—" ;
    medmij:mappingNote "Authorization Server is de DVA-component voor toestemming en autorisatie." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

