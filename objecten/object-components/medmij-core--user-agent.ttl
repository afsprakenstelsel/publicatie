@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--user-agent a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:user-agent ;
    medmij:componentClass medmij:Component ;
    medmij:elementName "MedMij Core bevat User Agent" ;
    medmij:layer "—" ;
    medmij:mappingNote "User Agent is de front-endcomponent die Persoon bedient." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

