@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--oauth-client-list-ocl a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:oauth-client-list-ocl ;
    medmij:componentClass medmij:Dataproduct ;
    medmij:elementName "MedMij Core bevat OAuth Client List (OCL)" ;
    medmij:layer "—" ;
    medmij:mappingNote "OCL is het DataProduct voor validatie van DVP-clients door DVA." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

