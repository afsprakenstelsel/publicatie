@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-authorization-server--openid-connect-oidc a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:openid-connect-oidc ;
    medmij:componentClass medmij:Specification ;
    medmij:elementName "Authorization Server implementeert OpenID Connect (OIDC)" ;
    medmij:layer "—" ;
