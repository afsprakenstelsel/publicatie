@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-authenticeren--openid-connect-oidc a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:openid-connect-oidc ;
    medmij:componentClass medmij:Specification ;
    medmij:elementName "Authenticeren bevat OpenID Connect (OIDC)" ;
    medmij:layer "—" ;
    medmij:mappingNote "Authenticatiemodule gebruikt OIDC voor BSN-ophaling via DigiD." ;
    medmij:whole obj:authenticeren ;
    medmij:wholeClass medmij:Module .

