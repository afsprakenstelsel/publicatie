@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:comp-delen--bevestigingsverklaring
    a medmij:Object, medmij:ObjectComponent ;
    medmij:elementName "Delen bevat Bevestigingsverklaring" ;
    medmij:code "—" ;
    medmij:objectClass medmij:ObjectComponent ;
    medmij:layer "—" ;
    medmij:mappingNote "Bevestigingsverklaring is de DataSet bij de Delen-autorisatie." ;
    medmij:whole obj:delen ;
    medmij:wholeClass medmij:Service ;
    medmij:component obj:bevestigingsverklaring ;
    medmij:componentClass medmij:Dataset .
