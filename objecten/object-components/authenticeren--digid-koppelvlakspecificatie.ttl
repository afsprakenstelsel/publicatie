@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-authenticeren--digid-koppelvlakspecificatie a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:digid-koppelvlakspecificatie ;
    medmij:componentClass medmij:Specification ;
    medmij:elementName "Authenticeren bevat DigiD Koppelvlakspecificatie" ;
    medmij:layer "—" ;
    medmij:mappingNote "Authenticatiemodule conformeert aan DigiD koppelvlakspecificatie." ;
    medmij:whole obj:authenticeren ;
    medmij:wholeClass medmij:Module .

