@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--dvp-server a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:dvp-server ;
    medmij:componentClass medmij:Component ;
    medmij:elementName "MedMij Core bevat DVP Server" ;
    medmij:layer "—" ;
    medmij:mappingNote "DVP Server is de applicatiecomponent aan de persoonskant." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

