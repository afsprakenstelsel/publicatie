@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:comp-medmij-core--aanbiederslijst-zal a medmij:Object,
        medmij:ObjectComponent ;
    medmij:code "—" ;
    medmij:component obj:aanbiederslijst-zal ;
    medmij:componentClass medmij:Dataproduct ;
    medmij:elementName "MedMij Core bevat Aanbiederslijst (ZAL)" ;
    medmij:layer "—" ;
    medmij:mappingNote "ZAL is het centrale DataProduct voor endpoint-routing door DVP." ;
    medmij:whole obj:medmij-core ;
    medmij:wholeClass medmij:Framework .

