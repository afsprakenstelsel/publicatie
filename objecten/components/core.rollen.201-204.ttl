@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:authorization-server
    a medmij:Object, medmij:Component ;
    medmij:elementName "Authorization Server" ;
    medmij:code "core.rollen.201 / 204" ;
    medmij:objectClass medmij:Component ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Beheert toestemming en autorisatie namens DVA; tevens Authentication Client." .
