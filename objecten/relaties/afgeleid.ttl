obj:authenticeren medmij:hasRequirement obj:digid-als-authenticatiemiddel-niveau-substantieel ;
    medmij:hasSpecification obj:digid-koppelvlakspecificatie,
        obj:openid-connect-oidc .

obj:autoriseren-met-langdurige-toestemming medmij:hasRequirement obj:refresh-token-geldigheid-max-6-maanden,
        obj:toestemmingslog-bij-dva-bijhouden ;
    medmij:hasSpecification obj:pkce-rfc-7636 .

obj:autoriseren-zonder-langdurige-toestemming medmij:hasRequirement obj:refresh-token-geldigheid-max-6-maanden,
        obj:toestemmingslog-bij-dva-bijhouden ;
    medmij:hasSpecification obj:pkce-rfc-7636 .

obj:backchannel-nodes-controleren-whitelist-voor-verkeer medmij:governedBy obj:opvragen-whitelist .

