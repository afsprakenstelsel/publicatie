medmij:governedBy a rdf:Property ;
    rdfs:comment "Verbindt een Arrangement met het Module waaronder het valt (op basis van codeprefix)."@nl .

medmij:hasRequirement a rdf:Property ;
    rdfs:comment "Verbindt een Module of Service met een Eis die erop van toepassing is."@nl .

medmij:hasSpecification a rdf:Property ;
    rdfs:comment "Verbindt een Module of Service met een Specificatie die erop van toepassing is."@nl .

medmij:specifiesArrangement a rdf:Property ;
    rdfs:comment "Verbindt een Eis of Specificatie met de Afspraak die zij nader uitwerkt (zelfde code)."@nl .

obj:opvragen-aanbiederslijst medmij:hasSpecification obj:medmij-interfaceversie-zal-formaat .

