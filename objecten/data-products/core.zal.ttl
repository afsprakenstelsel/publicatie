@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:aanbiederslijst-zal
    a medmij:Object, medmij:DataProduct ;
    medmij:elementName "Aanbiederslijst (ZAL)" ;
    medmij:code "(core.zal.*)" ;
    medmij:objectClass medmij:DataProduct ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Bevat welke Aanbieders welke Gegevensdiensten op welke endpoints aanbieden; opgehaald door DVP." .
