@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:aanbiedersregister-reg
    a medmij:Object, medmij:DataProduct ;
    medmij:elementName "Aanbiedersregister (REG)" ;
    medmij:code "(core.functies.*)" ;
    medmij:objectClass medmij:DataProduct ;
    medmij:layer "Business" ;
    medmij:mappingNote "Publiek raadpleegbaar register van Aanbieders en hun gegevensdiensten; voor mensen leesbaar." .
