@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:oauth-client-list-ocl
    a medmij:Object, medmij:DataProduct ;
    medmij:elementName "OAuth Client List (OCL)" ;
    medmij:code "(core.ocl.*)" ;
    medmij:objectClass medmij:DataProduct ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Bevat DVP-clientnamen, toegestane diensten en notificatieadressen; opgehaald door DVA." .
