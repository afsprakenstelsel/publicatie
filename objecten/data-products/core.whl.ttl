@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:whitelist-whl a medmij:DataProduct,
        medmij:Object ;
    medmij:code "(core.whl.*)" ;
    medmij:elementName "Whitelist (WHL)" ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Bevat actieve Nodes in het MedMij-netwerk; opgehaald door DVP en DVA." .

