@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:authenticeren
    a medmij:Object, medmij:Module ;
    medmij:elementName "Authenticeren" ;
    medmij:code "(core.authn.*)" ;
    medmij:objectClass medmij:Module ;
    medmij:layer "Business/Applicatie" ;
    medmij:mappingNote "Identiteitsvaststelling Persoon via externe Authentication Server (DigiD)." .
