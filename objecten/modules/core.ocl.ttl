@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:opvragen-oauth-client-list
    a medmij:Object, medmij:Module ;
    medmij:elementName "Opvragen OAuth Client List" ;
    medmij:code "(core.ocl.*)" ;
    medmij:objectClass medmij:Module ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "DVA haalt OCL op bij MedMij Registratie; valideert DVP-clients." .
