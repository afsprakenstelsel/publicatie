@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:autoriseren-zonder-langdurige-toestemming
    a medmij:Object, medmij:Module ;
    medmij:elementName "Autoriseren (zonder langdurige toestemming)" ;
    medmij:code "(core.authoz.*)" ;
    medmij:objectClass medmij:Module ;
    medmij:layer "Business/Applicatie" ;
    medmij:mappingNote "OAuth Authorization Code flow inclusief beschikbaarheids- en ontvankelijkheidstoets." .
