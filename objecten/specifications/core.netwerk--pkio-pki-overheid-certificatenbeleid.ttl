@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:pkio-pki-overheid-certificatenbeleid a medmij:Object,
        medmij:Specification ;
    medmij:code "(core.netwerk.*)" ;
    medmij:elementName "PKIO (PKI Overheid) Certificatenbeleid" ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Certificaatbeleid voor overheids-PKI; geldt voor Nodes in MedMij-netwerk." .

