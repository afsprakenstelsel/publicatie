@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:medmij-interfaceversie-zal-formaat
    a medmij:Object, medmij:Specification ;
    medmij:elementName "MedMij Interfaceversie (ZAL-formaat)" ;
