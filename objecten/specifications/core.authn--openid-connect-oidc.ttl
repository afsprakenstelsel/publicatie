@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:openid-connect-oidc a medmij:Object,
        medmij:Specification ;
    medmij:code "(core.authn.*)" ;
    medmij:elementName "OpenID Connect (OIDC)" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Authenticatielaag bovenop OAuth 2.0; gebruikt voor BSN-ophaling via DigiD." .

