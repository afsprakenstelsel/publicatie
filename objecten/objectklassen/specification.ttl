@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:class-specification a medmij:Object,
        medmij:ObjectClass ;
    medmij:classCode "Specification" ;
    medmij:code "—" ;
    medmij:definition "Een externe of interne standaard of interface-definitie waarnaar in verantwoordelijkheden wordt verwezen." ;
    medmij:dutchName "Specificatie" ;
    medmij:elementName "Specificatie" ;
    medmij:examples "OAuth 2.0, FHIR R4, OpenID Connect, MedMij Interfaceversie (ZAL/OCL-formaat)" ;
    medmij:layer "—" ;
    medmij:mappingNote "Externe of interne standaard waarnaar in verantwoordelijkheden wordt verwezen." .

