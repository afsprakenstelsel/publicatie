@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:token-endpoint-per-aanbiedergegevensdienst
    a medmij:Object, medmij:DataResource ;
    medmij:elementName "Token endpoint (per AanbiederGegevensdienst)" ;
    medmij:code "(core.authoz.*)" ;
    medmij:objectClass medmij:DataResource ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Het adres waarop de DVP Server een access-token (en refresh-token) ophaalt." .
