@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:notificatie-endpoint-dvp-abonneren a medmij:DataResource,
        medmij:Object ;
    medmij:code "(ext.abonneren.*)" ;
    medmij:elementName "Notificatie-endpoint (DVP, Abonneren)" ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Het adres waarop de DVP Server pushberichten ontvangt van DVA (extensie Abonneren)." .

