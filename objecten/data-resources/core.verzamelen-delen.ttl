@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:resource-endpoint-per-aanbiedergegevensdienst a medmij:DataResource,
        medmij:Object ;
    medmij:code "(core.verzamelen/delen.*)" ;
    medmij:elementName "Resource endpoint (per AanbiederGegevensdienst)" ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Het adres van de Resource Server voor het feitelijk ophalen of versturen van gezondheidsgegevens." .

