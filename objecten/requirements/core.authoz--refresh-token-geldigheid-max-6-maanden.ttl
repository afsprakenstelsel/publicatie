@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:refresh-token-geldigheid-max-6-maanden
    a medmij:Object, medmij:Requirement ;
    medmij:elementName "Refresh-token geldigheid max. 6 maanden" ;
    medmij:code "(core.authoz.*)" ;
    medmij:objectClass medmij:Requirement ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Bij langdurige toestemming; nieuw refresh-token bij elke inruil." .
