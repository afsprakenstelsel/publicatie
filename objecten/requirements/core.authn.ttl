obj:digid-als-authenticatiemiddel-niveau-substantieel
    a medmij:Object, medmij:Requirement ;
    medmij:elementName "DigiD als authenticatiemiddel (niveau Substantieel)" ;
    medmij:code "(core.authn.*)" ;
    medmij:objectClass medmij:Requirement ;
    medmij:layer "Applicatie" ;
