@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:toestemmingslog-bij-dva-bijhouden a medmij:Object,
        medmij:Requirement ;
    medmij:code "(core.authoz.*)" ;
    medmij:elementName "Toestemmingslog bij DVA bijhouden" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "DVA logt elke afgegeven toestemming inclusief Persoon-identiteit en gegevensdienst." .

