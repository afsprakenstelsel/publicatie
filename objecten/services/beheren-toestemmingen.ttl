@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:beheren-toestemmingen
    a medmij:Object, medmij:Service ;
    medmij:elementName "Beheren Toestemmingen" ;
    medmij:code "—" ;
    medmij:objectClass medmij:Service ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVA biedt Persoon via DVP de functie om langdurige toestemmingen te beheren." .
