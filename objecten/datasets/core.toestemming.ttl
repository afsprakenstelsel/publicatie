@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:beeindigingsverklaring
    a medmij:Object, medmij:DataSet ;
    medmij:elementName "Beeindigingsverklaring" ;
    medmij:code "(core.toestemming.*)" ;
    medmij:objectClass medmij:DataSet ;
    medmij:layer "Business" ;
    medmij:mappingNote "Gegevensset waarmee Persoon een abonnement of langdurige toestemming intrekt." .
