@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:gezondheidsgegevens-generiek
    a medmij:Object, medmij:DataSet ;
    medmij:elementName "Gezondheidsgegevens (generiek)" ;
    medmij:code "(informatiemodel.*)" ;
    medmij:objectClass medmij:DataSet ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "De inhoudelijke gegevensset die via Verzamelen of Delen wordt uitgewisseld; per gegevensdienst gespecificeerd." .
