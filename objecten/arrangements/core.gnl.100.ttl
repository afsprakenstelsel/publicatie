@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:medmij-beheer-beheert-en-publiceert-gnl
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "MedMij Beheer beheert en publiceert GNL" ;
    medmij:code "core.gnl.100" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "GNL beschrijft gebruiksvriendelijke namen per Gegevensdienst; voldoet aan Informatiemodellen." ;
    medmij:arrangementText "MedMij Beheer beheert en publiceert de Gegevensdienstnamenlijst. Deze beschrijft welke gebruikersvriendelijke namen horen bij welke Gegevensdiensten. De Gegevensdienstnamenlijst voldoet aan wat over haar is bepaald in de Informatiemodellen." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .
