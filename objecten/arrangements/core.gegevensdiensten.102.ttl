@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:medmij-beheer-neemt-dva-op-in-aanbiederslijst-na-toetsing a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "MedMij Beheer zal alleen in de Aanbiederslijst opnemen dat een zekere Gegevensdienst door een zekere Aanbieder via een Dienstverlener aanbieder wordt aangeboden, indien zij (Stichting MedMij) heeft vastgesteld dat de Dienstverlener aanbieder voldoet aan de specifiek op die Gegevensdienst toepasselijke eisen en de normen die staan beschreven in de DAP en aanverwante documenten." ;
    medmij:code "core.gegevensdiensten.102" ;
    medmij:elementName "MedMij Beheer neemt DVA op in Aanbiederslijst na toetsing" ;
    medmij:layer "Business" ;
    medmij:mappingNote "Opname alleen als DVA voldoet aan DAP-eisen voor de betreffende Gegevensdienst." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> ;
    medmij:toelichting "De Dienstverlener aanbieder heeft minimaal één Aanbieder nodig om zich te kwalificeren in het MedMij Afsprakenstelsel voor een informatiestandaard." .

