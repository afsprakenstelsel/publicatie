@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:persoon-gebruikt-user-agent
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "Persoon gebruikt User Agent" ;
    medmij:code "core.rollen.203" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Persoon gebruikt één User Agent voor toegang tot DVP Server en Authorization Server." ;
    medmij:arrangementText "Persoon gebruikt één geautomatiseerde rol User Agent voor toegang tot de functionaliteit van DVP Server en Authorization Server. User Agent presenteert de functionaliteit aan Persoon, spreekt DVP Server aan en verwijst de Persoon naar de Authorization Server." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .
