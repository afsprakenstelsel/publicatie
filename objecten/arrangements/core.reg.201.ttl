@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:register-gebaseerd-op-json-lijst
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "Register gebaseerd op JSON-lijst" ;
    medmij:code "core.reg.201" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Technische lijst in JSON-formaat; eerste versie uiterlijk 31 oktober 2023." ;
    medmij:arrangementText "Het Aanbiedersregister is gebaseerd op de inhoud van technische lijst(en) die in JSON-formaat wordt aangeboden. MedMij Beheer levert uiterlijk 31 oktober 2023 de eerste versie van de lijst waarop het Aanbiedersregister gebaseerd is." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .
