@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:dvp-biedt-dvp-server-aan-persoon a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "Dienstverlener persoon biedt aan Persoon, in het kader van de toepasselijke Dienstverleningsovereenkomst, een geautomatiseerde rol ter gebruik, hier genoemd: DVP Server. Eén Dienstverlener persoon biedt één of meerdere DVP Servers en elke DVP Server wordt door één Dienstverlener persoon geboden." ;
    medmij:code "core.rollen.200" ;
    medmij:elementName "DVP biedt DVP Server aan Persoon" ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "DVP biedt geautomatiseerde applicatierol DVP Server; 1 DVP — 1..n DVP Servers." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

