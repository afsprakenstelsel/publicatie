obj:medmij-beheer-biedt-functie-opvragen-gnl-aan-deelnemers
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "MedMij Beheer biedt functie Opvragen GNL aan Deelnemers" ;
    medmij:code "core.gnl.101" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "Deelnemers kunnen via stroomdiagram actuele versie GNL opvragen." ;
    medmij:arrangementText "MedMij Beheer biedt aan Deelnemers de functie Opvragen Gegevensdienstnamenlijst om de actuele versie van die Gegevensdienstnamenlijst op te vragen. Betrokken rollen gebruiken hiertoe het betreffende stroomdiagram." ;
