obj:nodes-valideren-whitelist-hostnames-zijn-fqdn-conform-rfc3696
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "Nodes valideren Whitelist; hostnames zijn FQDN conform RFC3696" ;
    medmij:code "core.whl.304" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Technologie" ;
    medmij:mappingNote "Elke nieuw verkregen Whitelist gevalideerd; alle hostnames zijn fully-qualified domain names." ;
    medmij:arrangementText "Nodes valideren elke nieuw verkregen Whitelist tegen het XML-schema van de Whitelist. Alle hostnames op de Whitelist zijn fully-qualified domain names, conform RFC3696, sectie 2." ;
