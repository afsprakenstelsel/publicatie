@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:authorization-server-gebruikt-authentication-server
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "Authorization Server gebruikt Authentication Server" ;
    medmij:code "core.rollen.205" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "Authorization Server gebruikt externe Authentication Server (DigiD) als Authentication Client." ;
    medmij:arrangementText "Ten behoeve van het authenticeren van Persoon, zal de betrokken Authorization Server, in de rol van Authentication Client, gebruikmaken van de Authentication Server van een Dienstverlener authenticatie." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .
