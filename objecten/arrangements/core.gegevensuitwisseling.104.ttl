obj:dvp-notificeert-persoon-bij-succesvolle-automatische-uitwisseling
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "DVP notificeert Persoon bij succesvolle automatische uitwisseling" ;
    medmij:code "core.gegevensuitwisseling.104" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "Notificatie op door Persoon gewenste wijze (app, e-mail, SMS)." ;
    medmij:arrangementText "De Dienstverlener persoon is verplicht de Persoon van succesvolle automatische uitwisseling te notificeren op een door de Persoon gewenste manier. Dit kan bijvoorbeeld in de app/browser, per e-mail of per SMS." ;
