@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj: <https://register.medmij.nl/objects/> .

obj:dvp-notificeert-persoon-bij-inactief-account a medmij:Arrangement,
        medmij:Object ;
    medmij:arrangementText "De Dienstverlener persoon moet de Persoon notificeren per e-mail of (als de DVP dit aanbiedt) per SMS van het feit dat het account de status 'inactief' heeft gekregen en indien van toepassing geen gebruikmaakt van aanwezige langdurige toestemmingen, totdat de Persoon opnieuw inlogt." ;
    medmij:code "core.account.103" ;
    medmij:elementName "DVP notificeert Persoon bij inactief account" ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVP stuurt e-mail of SMS bij statuswijziging naar inactief; langdurige toestemmingen onderbroken." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .

