@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:deelnemersovereenkomst
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "Deelnemersovereenkomst" ;
    medmij:code "—" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "De overeenkomst waarmee een Deelnemer zich bindt aan het afsprakenstelsel (zie Agreement in datamodel)." .
