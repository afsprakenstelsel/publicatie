obj:persoon-moet-actief-account-hebben-bij-dvp
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "Persoon moet een actief account hebben bij DVP" ;
    medmij:code "core.account.100" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "Vereist voor inrichten Dossier en gebruik MedMij-functies." ;
    medmij:arrangementText "Voor het inrichten van een MedMij dossier en voor het gebruikmaken van de verschillende MedMij functies moet de Persoon een actief account hebben bij de Dienstverlener persoon." ;
