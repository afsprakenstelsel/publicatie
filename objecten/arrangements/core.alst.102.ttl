obj:medmij-beheer-biedt-functie-opvragen-aanbiederslijst
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "MedMij Beheer biedt functie Opvragen Aanbiederslijst" ;
    medmij:code "core.alst.102" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "DVP's kunnen actuele Aanbiederslijst opvragen via stroomdiagram." ;
    medmij:arrangementText "MedMij Beheer biedt aan Dienstverleners persoon een functie (Opvragen Aanbiederslijst) om de actuele versie van die Aanbiederslijst op te vragen. Betrokken rollen gebruiken hiertoe het betreffende stroomdiagram." ;
