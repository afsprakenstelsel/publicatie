@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:register-bevat-namen-identificerende-gegevens-en-uitwisselingsstatus
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "Register bevat namen, identificerende gegevens en uitwisselingsstatus" ;
    medmij:code "core.reg.102" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "Alleen Aanbieders die voldoen aan DAP-eisen en -normen zijn opgenomen." ;
    medmij:arrangementText "Het Aanbiedersregister bevat de gebruiksvriendelijke namen van aangesloten aanbieders, de bijbehorende identificerende gegevens, de bijbehorende gegevensdiensten en de uitwisselingsstatus. Het Aanbiedersregister bevat alleen de gegevens van aanbieders die voldoen aan de eisen en normen die in de DAP beschreven staan." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .
