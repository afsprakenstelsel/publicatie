obj:dva-biedt-authorization-server
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "DVA biedt Authorization Server" ;
    medmij:code "core.rollen.201" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Applicatie" ;
    medmij:mappingNote "DVA biedt Authorization Server voor uitwisseling namens Aanbieders; altijd gecombineerd met Resource Server." ;
    medmij:arrangementText "Dienstverlener aanbieder biedt een geautomatiseerde rol Authorization Server, voor het namens Aanbieders uitwisselen van gezondheidsinformatie met DVP Server. Deze rol wordt altijd gecombineerd met een Resource Server." ;
