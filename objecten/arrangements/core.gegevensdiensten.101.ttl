@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix medmij: <https://register.medmij.nl/ontology/> .
@prefix obj:    <https://register.medmij.nl/objects/> .

obj:dva-ontsluit-minstens-n-gegevensdienst
    a medmij:Object, medmij:Arrangement ;
    medmij:elementName "DVA ontsluit minstens één Gegevensdienst" ;
    medmij:code "core.gegevensdiensten.101" ;
    medmij:objectClass medmij:Arrangement ;
    medmij:layer "Business" ;
    medmij:mappingNote "Elke DVA ontsluit op elk moment minimaal één Gegevensdienst (Verzamelen of Delen)." ;
    medmij:arrangementText "Elke Dienstverlener aanbieder ontsluit op elk moment minstens één Gegevensdienst." ;
    medmij:toelichting "Het ontsluiten van een Gegevensdienst door een Dienstverlener aanbieder is, in deze versie van het MedMij Afsprakenstelsel, hetzij in het kader van Verzamelen of in het kader van Delen van zekere gezondheidsinformatie. De term 'ontsluiten' wordt hier gebruikt in plaats van de term 'aanbieden', omdat als aanbieder van een Gegevensdienst de Aanbieder wordt gezien, niet de Deelnemer (Dienstverlener aanbieder). De Deelnemer ontsluit de Gegevensdienst dus namens de Aanbieder die die Gegevensdienst aanbiedt." ;
    medmij:sourceUrl <https://afsprakenstelsel.medmij.nl/asverplicht/mmverplicht/verantwoordelijkheden-core> .
